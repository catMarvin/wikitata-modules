{
  "name": "@wikitata/content-creation",
  "version": "0.2.0",
  "description": "Video Designer (AI-describe → render → blend) + Compositor (layered titling) — shared module across the wikiTaTa ecosystem",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/catMarvin/wikitata-modules.git",
    "directory": "packages/content-creation"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./routes": {
      "types": "./dist/routes/index.d.ts",
      "import": "./dist/routes/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./migrations": {
      "types": "./dist/migrations/index.d.ts",
      "import": "./dist/migrations/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "MIGRATION.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "dependencies": {
    "ai": "^6.0.174",
    "@ai-sdk/gateway": "^3.0.109",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
